<script>
  import QRCode from 'qrcode';

  let _escAdded = false;

  function initFabs() {
    const fabStack   = document.getElementById('fabStack');
    const fabTrigger = document.getElementById('fabTrigger');
    const fsBtn      = document.getElementById('fsBtn');
    const fsEnter    = document.getElementById('fsEnter');
    const fsExit     = document.getElementById('fsExit');
    const soundBtn   = document.getElementById('soundBtn');
    const soundOn    = document.getElementById('soundOn');
    const soundOff   = document.getElementById('soundOff');
    const infoBtn    = document.getElementById('infoBtn');
    const authorBtn  = document.getElementById('authorBtn');
    const shareBtn   = document.getElementById('shareBtn');
    const infoModal  = document.getElementById('infoModal');
    const authorModal = document.getElementById('authorModal');
    const shareModal = document.getElementById('shareModal');
    const backdrop   = document.getElementById('fabBackdrop');
    const infoClose  = document.getElementById('infoClose');
    const authorClose = document.getElementById('authorClose');
    const shareClose = document.getElementById('shareClose');

    if (!fsBtn || !fabStack || !fabTrigger) return;

    // Hide fullscreen button when running as installed PWA (API unavailable in standalone)
    const isPWA = window.matchMedia('(display-mode: standalone)').matches
               || (navigator as any).standalone === true;
    if (isPWA) (fsBtn as HTMLElement).style.display = 'none';

    // --- Speed dial toggle ---
    function openDial() {
      fabStack.classList.add('open');
      fabTrigger.setAttribute('aria-expanded', 'true');
      (backdrop as HTMLElement).classList.add('open');
    }

    function closeDial() {
      fabStack.classList.remove('open');
      fabTrigger.setAttribute('aria-expanded', 'false');
      const anyModalOpen = infoModal!.classList.contains('open')
        || authorModal!.classList.contains('open')
        || shareModal!.classList.contains('open');
      if (!anyModalOpen) {
        (backdrop as HTMLElement).classList.remove('open');
      }
    }

    fabTrigger.onclick = () => {
      fabStack.classList.contains('open') ? closeDial() : openDial();
    };

    // --- Fullscreen ---
    function syncFsIcon() {
      const full = !!document.fullscreenElement;
      (fsEnter as HTMLElement).style.display = full ? 'none' : 'block';
      (fsExit as HTMLElement).style.display  = full ? 'block' : 'none';
    }

    fsBtn.onclick = () => {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(() => {});
      } else {
        document.exitFullscreen().catch(() => {});
      }
      closeDial();
    };

    document.removeEventListener('fullscreenchange', syncFsIcon);
    document.addEventListener('fullscreenchange', syncFsIcon);
    syncFsIcon();

    // --- Sound ---
    function syncSoundIcon() {
      const enabled = localStorage.getItem('verbGameSounds') !== 'false';
      (soundOn as HTMLElement).style.display  = enabled ? 'block' : 'none';
      (soundOff as HTMLElement).style.display = enabled ? 'none'  : 'block';
    }

    soundBtn!.onclick = () => {
      const enabled = localStorage.getItem('verbGameSounds') !== 'false';
      localStorage.setItem('verbGameSounds', enabled ? 'false' : 'true');
      syncSoundIcon();
      closeDial();
    };

    syncSoundIcon();

    // --- Modals ---
    function openModal(modal: HTMLElement) {
      closeAll();
      modal.classList.add('open');
      (backdrop as HTMLElement).classList.add('open');
    }

    function closeAll() {
      infoModal!.classList.remove('open');
      authorModal!.classList.remove('open');
      shareModal!.classList.remove('open');
      closeDial();
      (backdrop as HTMLElement).classList.remove('open');
    }

    infoBtn!.onclick     = () => openModal(infoModal as HTMLElement);
    authorBtn!.onclick   = () => openModal(authorModal as HTMLElement);
    infoClose!.onclick   = closeAll;
    authorClose!.onclick = closeAll;
    shareClose!.onclick  = closeAll;
    backdrop!.onclick    = closeAll;

    // --- Share ---
    const appUrl = window.location.origin;
    const shareText = 'Practice English irregular verbs the fun way! 🎮';

    const waLink  = document.getElementById('shareWa') as HTMLAnchorElement;
    const smsLink = document.getElementById('shareSms') as HTMLAnchorElement;
    const nativeBtn = document.getElementById('shareNativeBtn') as HTMLButtonElement;

    waLink.href  = `https://wa.me/?text=${encodeURIComponent(shareText + ' ' + appUrl)}`;
    smsLink.href = `sms:?body=${encodeURIComponent(shareText + ' ' + appUrl)}`;

    if (typeof navigator.share === 'function') {
      nativeBtn.style.display = 'flex';
      nativeBtn.onclick = () => {
        navigator.share({ title: 'Irregular Verbs Game', text: shareText, url: appUrl }).catch(() => {});
      };
    }

    shareBtn!.onclick = () => {
      openModal(shareModal as HTMLElement);
      closeDial();
      const canvas = document.getElementById('shareQrCanvas') as HTMLCanvasElement;
      QRCode.toCanvas(canvas, appUrl, { width: 180, margin: 1, color: { dark: '#1e1b4b', light: '#f9fafb' } }).catch(() => {});
    };

    if (!_escAdded) {
      _escAdded = true;
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          document.getElementById('infoModal')?.classList.remove('open');
          document.getElementById('authorModal')?.classList.remove('open');
          document.getElementById('shareModal')?.classList.remove('open');
          document.getElementById('fabStack')?.classList.remove('open');
          document.getElementById('fabTrigger')?.setAttribute('aria-expanded', 'false');
          document.getElementById('fabBackdrop')?.classList.remove('open');
        }
      });
    }
  }

  function setYear() {
    const el = document.getElementById('footerYear');
    if (el) el.textContent = String(new Date().getFullYear());
  }

  initFabs();
  setYear();
  document.addEventListener('astro:page-load', () => { initFabs(); setYear(); });
</script>

<script>
  import { trackAppSession } from '../utils/supabase.ts';

  const SID_KEY  = 'verbGame_sid';
  const NAME_KEY = 'verbGamePlayerName';

  function getOrCreateSid(): string {
    let sid = localStorage.getItem(SID_KEY);
    if (!sid) {
      sid = crypto.randomUUID();
      localStorage.setItem(SID_KEY, sid);
    }
    return sid;
  }

  function parseDevice(ua: string): string {
    if (/Mobi|Android/i.test(ua) && !/iPad/i.test(ua)) return 'mobile';
    if (/iPad|Tablet/i.test(ua)) return 'tablet';
    return 'desktop';
  }

  function parseBrowser(ua: string): string {
    if (/Edg\//i.test(ua)) return 'Edge';
    if (/OPR|Opera/i.test(ua)) return 'Opera';
    if (/Chrome/i.test(ua)) return 'Chrome';
    if (/Firefox/i.test(ua)) return 'Firefox';
    if (/Safari/i.test(ua)) return 'Safari';
    return 'Other';
  }

  function parseOS(ua: string): string {
    if (/iPhone/i.test(ua)) return 'iOS';
    if (/iPad/i.test(ua)) return 'iPadOS';
    if (/Android/i.test(ua)) return 'Android';
    if (/Mac OS X/i.test(ua)) return 'macOS';
    if (/Windows/i.test(ua)) return 'Windows';
    if (/Linux/i.test(ua)) return 'Linux';
    return 'Other';
  }

  function track() {
    try {
      const sid    = getOrCreateSid();
      const name   = localStorage.getItem(NAME_KEY) ?? '';
      const ua     = navigator.userAgent;
      trackAppSession(sid, name, parseDevice(ua), parseBrowser(ua), parseOS(ua));
    } catch {}
  }

  track();
  document.addEventListener('astro:page-load', track);
</script>

<script>
  const NAME_KEY = 'verbGamePlayerName';

  function checkName() {
    // Skip on admin pages — no player name needed there
    if (window.location.pathname.startsWith('/admin')) return;

    const name = localStorage.getItem(NAME_KEY)?.trim();
    if (name) return;

    const wrap  = document.getElementById('nameModalWrap') as HTMLElement;
    const form  = document.getElementById('nameModalForm') as HTMLFormElement;
    const input = document.getElementById('nameModalInput') as HTMLInputElement;

    if (!wrap) return;
    wrap.style.display = 'flex';

    // Focus input after animation
    setTimeout(() => input.focus(), 50);

    form.onsubmit = (e) => {
      e.preventDefault();
      const val = input.value.trim();
      if (!val) { input.focus(); return; }
      localStorage.setItem(NAME_KEY, val);
      wrap.style.display = 'none';
    };
  }

  document.addEventListener('astro:page-load', checkName);
  checkName();
</script>

<script>
  // Pull-to-refresh — listeners registered once (Astro module runs once)
  const PTR_THRESHOLD = 80; // finger travel in px to trigger reload

  let ptStartY = 0;
  let ptActive = false;
  let ptReady  = false;
  let ptrHiddenY = -120; // recalculated on each reset based on safe-area

  // Read the safe-area-inset-top CSS variable set on :root
  function getSafeAreaTop(): number {
    const raw = getComputedStyle(document.documentElement).getPropertyValue('--sat').trim();
    return parseFloat(raw) || 0;
  }

  // Hidden Y = enough to fully conceal the bubble above the viewport
  // (safe-area + ptrWrap padding 12px + bubble 46px + buffer 16px)
  function computeHiddenY(): number {
    return -(getSafeAreaTop() + 12 + 46 + 16);
  }

  function ptrReset() {
    ptrHiddenY = computeHiddenY();
    const wrap    = document.getElementById('ptrWrap')    as HTMLElement | null;
    const arrow   = document.getElementById('ptrArrow')   as HTMLElement | null;
    const spinner = document.getElementById('ptrSpinner') as HTMLElement | null;
    const bubble  = document.getElementById('ptrBubble')  as HTMLElement | null;
    if (!wrap) return;
    wrap.style.transition = '';
    wrap.style.transform  = `translateY(${ptrHiddenY}px)`;
    if (arrow)   { arrow.style.display = ''; arrow.style.transform = 'rotate(0deg)'; }
    if (spinner) { spinner.style.display = 'none'; }
    if (bubble)  { bubble.classList.remove('ptr-ready'); }
    ptActive = false;
    ptReady  = false;
  }

  document.addEventListener('touchstart', (e) => {
    if (window.scrollY > 5) return;
    ptStartY = e.touches[0].clientY;
    ptActive = true;
    ptReady  = false;
    ptrHiddenY = computeHiddenY();
    const wrap = document.getElementById('ptrWrap') as HTMLElement | null;
    if (wrap) wrap.style.transition = '';
  }, { passive: true });

  document.addEventListener('touchmove', (e) => {
    if (!ptActive) return;
    const deltaY = e.touches[0].clientY - ptStartY;
    if (deltaY <= 0) { ptActive = false; return; }

    // Prevent iOS rubber-band bounce while PTR is active
    e.preventDefault();

    const wrap   = document.getElementById('ptrWrap')   as HTMLElement | null;
    const arrow  = document.getElementById('ptrArrow')  as HTMLElement | null;
    const bubble = document.getElementById('ptrBubble') as HTMLElement | null;
    if (!wrap) return;

    // Multiplier: moves indicator from ptrHiddenY to 0 exactly at PTR_THRESHOLD
    // so the bubble lands at translateY(0) = padding-top (safe-area + 12px) below notch
    const range      = Math.abs(ptrHiddenY); // total distance to travel
    const multiplier = range / PTR_THRESHOLD;
    const indicatorY = Math.min(ptrHiddenY + deltaY * multiplier, 0);
    wrap.style.transform = `translateY(${indicatorY}px)`;

    // Arrow rotates 0→180° as progress goes 0→1
    const progress = Math.min(deltaY / PTR_THRESHOLD, 1);
    if (arrow) arrow.style.transform = `rotate(${progress * 180}deg)`;

    ptReady = deltaY >= PTR_THRESHOLD;
    if (bubble) bubble.classList.toggle('ptr-ready', ptReady);
  }, { passive: false });

  document.addEventListener('touchend', () => {
    if (!ptActive) return;
    ptActive = false;

    const wrap    = document.getElementById('ptrWrap')    as HTMLElement | null;
    const arrow   = document.getElementById('ptrArrow')   as HTMLElement | null;
    const spinner = document.getElementById('ptrSpinner') as HTMLElement | null;
    if (!wrap) return;

    if (ptReady) {
      // Hold in place, swap arrow→spinner, then reload
      wrap.style.transition = 'transform 0.2s ease';
      wrap.style.transform  = 'translateY(0px)';
      if (arrow)   arrow.style.display   = 'none';
      if (spinner) spinner.style.display = '';
      setTimeout(() => location.reload(), 700);
    } else {
      // Snap back
      wrap.style.transition = 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
      wrap.style.transform  = `translateY(${ptrHiddenY}px)`;
    }
  }, { passive: true });

  document.addEventListener('astro:page-load', ptrReset);
  ptrReset();
</script>
