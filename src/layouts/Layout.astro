---
import { ClientRouter } from 'astro:transitions';
interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}
const { title, description = 'Learn English irregular verbs the fun way', bodyClass = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- PWA -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#667eea">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Verb Game">
  <link rel="apple-touch-icon" href="/favicon.svg">

  <ClientRouter />

  <!-- Inter font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body class={bodyClass}>
  <slot />

  <!-- FAB Stack (bottom-right) -->
  <div class="fab-stack">
    <button class="fab-btn" id="fsBtn" title="Pantalla completa" aria-label="Toggle fullscreen">
      <svg id="fsEnter" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M8 3H5a2 2 0 0 0-2 2v3M21 8V5a2 2 0 0 0-2-2h-3M3 16v3a2 2 0 0 0 2 2h3M16 21h3a2 2 0 0 0 2-2v-3"/>
      </svg>
      <svg id="fsExit" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
        <path d="M8 3v3a2 2 0 0 1-2 2H3M21 8h-3a2 2 0 0 1-2-2V3M3 16h3a2 2 0 0 0 2 2v3M16 21v-3a2 2 0 0 1 2-2h3"/>
      </svg>
    </button>

    <button class="fab-btn" id="soundBtn" title="Sonido" aria-label="Toggle sound">
      <svg id="soundOn" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/>
      </svg>
      <svg id="soundOff" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <line x1="23" y1="9" x2="17" y2="15"/>
        <line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
    </button>

    <button class="fab-btn" id="infoBtn" title="¿Cómo jugar?" aria-label="How to play">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
        <line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
    </button>

    <button class="fab-btn" id="authorBtn" title="Sobre el autor" aria-label="About author">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
    </button>
  </div>

  <!-- Fixed footer -->
  <footer class="site-footer">
    © <span id="footerYear"></span>
    <a href="https://jcvb.com.co" target="_blank" rel="noopener noreferrer">Julián Valdés</a>
    · All rights reserved
  </footer>

  <!-- Backdrop -->
  <div class="fab-backdrop" id="fabBackdrop"></div>

  <!-- Info Modal -->
  <div class="fab-modal" id="infoModal" role="dialog" aria-modal="true" aria-label="Cómo jugar">
    <div class="modal-header">
      <h2>🎮 Cómo jugar</h2>
      <button class="modal-close" id="infoClose" aria-label="Cerrar">✕</button>
    </div>
    <div class="modal-body">
      <div class="mode-item">
        <span class="mode-emoji">⚡</span>
        <div>
          <strong>Quick Match</strong>
          <p>4 opciones para elegir la forma correcta del verbo. Rápido y directo.</p>
        </div>
      </div>
      <div class="mode-item">
        <span class="mode-emoji">🏃</span>
        <div>
          <strong>Speed Challenge</strong>
          <p>60 segundos para emparejar verbos entre dos columnas. ¡Cuantos más, mejor!</p>
        </div>
      </div>
      <div class="mode-item">
        <span class="mode-emoji">⌨️</span>
        <div>
          <strong>Type Master</strong>
          <p>Escribe la forma del verbo correctamente. Ideal para practicar ortografía.</p>
        </div>
      </div>
      <div class="mode-item">
        <span class="mode-emoji">🃏</span>
        <div>
          <strong>Memory Cards</strong>
          <p>Voltea tarjetas para encontrar los pares de verbos. 6, 8 o 10 pares.</p>
        </div>
      </div>
      <div class="mode-item">
        <span class="mode-emoji">♾️</span>
        <div>
          <strong>Practice</strong>
          <p>Navega o autoevalúate con todos los verbos a tu propio ritmo.</p>
        </div>
      </div>
      <div class="mode-tip">
        💡 Ve a <strong>Settings ⚙️</strong> para elegir qué formas verbales practicar.
      </div>
    </div>
  </div>

  <!-- Author Modal -->
  <div class="fab-modal" id="authorModal" role="dialog" aria-modal="true" aria-label="Sobre el autor">
    <div class="modal-header">
      <h2>👤 Autor</h2>
      <button class="modal-close" id="authorClose" aria-label="Cerrar">✕</button>
    </div>
    <div class="modal-body author-body">
      <img
        src="https://jcvb.com.co/assets/images/profile.JPEG"
        alt="Julián Camilo Valdés Bello"
        class="author-photo"
        width="88"
        height="88"
        style="width:88px;height:88px;min-width:88px;max-width:88px;border-radius:50%;object-fit:cover;object-position:center 30%;display:block;flex-shrink:0;"
      />
      <h3 class="author-name">Julián Camilo Valdés Bello</h3>
      <span class="author-role">Tech Lead &amp; Software Architect · OMNI.PRO</span>
      <p class="author-bio">
        Software specialist con 8+ años de experiencia en microservicios, infraestructura cloud e integración de IA. Creé este juego para hacer más divertido el aprendizaje de los verbos irregulares en inglés.
      </p>
      <div class="author-links">
        <a href="https://jcvb.com.co" target="_blank" rel="noopener noreferrer" class="author-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          jcvb.com.co
        </a>
        <a href="https://github.com/jvaldesbit" target="_blank" rel="noopener noreferrer" class="author-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
          github.com/jvaldesbit
        </a>
        <a href="https://github.com/jvaldesbit/irregular-verbs-game" target="_blank" rel="noopener noreferrer" class="author-link author-link--repo">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
          Repo del proyecto
        </a>
      </div>
    </div>
  </div>
</body>
</html>

<style is:global>
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --purple:      #667eea;
    --purple-dark: #764ba2;
    --green:       #10b981;
    --green-dark:  #059669;
    --red:         #ef4444;
    --amber:       #f59e0b;
    --r-sm:  0.625rem;
    --r-md:  1rem;
    --r-lg:  1.5rem;
    --r-xl:  2rem;
    --sh-sm: 0 2px 8px rgba(0,0,0,0.10);
    --sh-md: 0 8px 24px rgba(0,0,0,0.14);
    --sh-lg: 0 16px 48px rgba(0,0,0,0.18);
    --t: 0.18s cubic-bezier(0.4, 0, 0.2, 1);
  }

  html {
    font-size: 16px;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  body {
    font-family: var(--font);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100dvh;
  }

  @media (min-width: 768px) {
    html { font-size: 17px; }
  }

  @media (min-width: 1024px) {
    html { font-size: 18px; }
  }

  /* ── Fixed footer ── */
  .site-footer {
    position: fixed;
    bottom: 0.6rem;
    left: 1rem;
    z-index: 9990;
    font-size: 0.68rem;
    font-weight: 500;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.02em;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  .site-footer a {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    pointer-events: auto;
    transition: color var(--t);
  }

  .site-footer a:hover {
    color: rgba(255,255,255,0.85);
  }

  /* ── FAB Stack ── */
  .fab-stack {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 9999;
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    align-items: center;
  }

  .fab-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.22);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 12px rgba(0,0,0,0.25);
    transition: background var(--t), transform var(--t);
    flex-shrink: 0;
  }

  .fab-btn:hover {
    background: rgba(255,255,255,0.38);
    transform: scale(1.12);
  }

  .fab-btn:active { transform: scale(0.96); }

  .fab-btn svg {
    width: 18px;
    height: 18px;
    pointer-events: none;
  }

  /* ── Backdrop ── */
  .fab-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9997;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }

  .fab-backdrop.open { display: block; }

  /* ── Modals ── */
  .fab-modal {
    position: fixed;
    z-index: 9998;
    bottom: 0;
    left: 0;
    right: 0;
    background: #fff;
    border-radius: var(--r-xl) var(--r-xl) 0 0;
    box-shadow: var(--sh-lg);
    transform: translateY(110%);
    transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    max-height: 85dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    pointer-events: none;
  }

  .fab-modal.open {
    pointer-events: auto;
  }

  .fab-modal.open { transform: translateY(0); }

  @media (min-width: 600px) {
    .fab-modal {
      top: 50%;
      left: 50%;
      right: auto;
      bottom: auto;
      width: min(480px, 94vw);
      border-radius: var(--r-xl);
      transform: translate(-50%, -44%) scale(0.96);
      opacity: 0;
      transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.28s ease;
    }
    .fab-modal.open {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
    }
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem 1rem;
    border-bottom: 1px solid rgba(0,0,0,0.07);
    flex-shrink: 0;
  }

  .modal-header h2 {
    font-size: 1.2rem;
    font-weight: 800;
    color: #1e1b4b;
    letter-spacing: -0.02em;
  }

  .modal-close {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: #f3f4f6;
    color: #6b7280;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--t), color var(--t);
    flex-shrink: 0;
  }

  .modal-close:hover { background: #e5e7eb; color: #374151; }

  .modal-body {
    padding: 1.25rem 1.5rem 1.75rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Info modal */
  .mode-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.85rem 1rem;
    background: #f9fafb;
    border-radius: var(--r-md);
    border: 1px solid #f3f4f6;
  }

  .mode-emoji {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .mode-item strong {
    display: block;
    font-size: 0.95rem;
    font-weight: 800;
    color: #1e1b4b;
    margin-bottom: 0.2rem;
  }

  .mode-item p {
    font-size: 0.85rem;
    color: #6b7280;
    line-height: 1.5;
    font-weight: 500;
  }

  .mode-tip {
    font-size: 0.85rem;
    color: #4b5563;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: var(--r-md);
    padding: 0.75rem 1rem;
    line-height: 1.5;
  }

  .mode-tip strong { color: #92400e; }

  /* Author modal */
  .author-body { align-items: center; text-align: center; gap: 0.85rem; }

  .author-photo {
    width: 88px;
    height: 88px;
    min-width: 88px;
    max-width: 88px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center 20%;
    box-shadow: 0 0 0 3px white, var(--sh-md);
    flex-shrink: 0;
    display: block;
  }

  .author-name {
    font-size: 1.2rem;
    font-weight: 800;
    color: #1e1b4b;
    letter-spacing: -0.02em;
  }

  .author-role {
    font-size: 0.78rem;
    font-weight: 700;
    color: #667eea;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: -0.4rem;
  }

  .author-bio {
    font-size: 0.88rem;
    color: #6b7280;
    line-height: 1.65;
    font-weight: 500;
    max-width: 340px;
  }

  .author-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    width: 100%;
    max-width: 300px;
    margin-top: 0.25rem;
  }

  .author-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.25rem;
    background: #f9fafb;
    border: 1.5px solid #e5e7eb;
    border-radius: var(--r-md);
    text-decoration: none;
    color: #374151;
    font-size: 0.9rem;
    font-weight: 700;
    transition: all var(--t);
  }

  .author-link:hover {
    background: #f3f4f6;
    border-color: #667eea;
    color: #667eea;
    transform: translateY(-2px);
    box-shadow: var(--sh-sm);
  }

  .author-link--repo {
    background: #f0fdf4;
    border-color: #bbf7d0;
    color: #065f46;
  }

  .author-link--repo:hover {
    border-color: #10b981;
    color: #059669;
  }

  .author-link svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* ── Shared back button ── */
  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: white;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.55rem 1rem;
    border-radius: var(--r-sm);
    background: rgba(255,255,255,0.2);
    transition: background var(--t);
    white-space: nowrap;
    min-height: 44px;
  }

  .back-btn:hover { background: rgba(255,255,255,0.32); }

  /* ── Shared stats badge ── */
  .stat-badge {
    background: rgba(255,255,255,0.2);
    color: white;
    padding: 0.45rem 0.9rem;
    border-radius: var(--r-sm);
    font-size: 0.9rem;
    font-weight: 600;
    min-height: 44px;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .stat-badge strong {
    font-weight: 800;
    font-size: 1.05rem;
  }

  /* ── Progress bar at page bottom ── */
  .page-progress {
    height: 5px;
    background: rgba(255,255,255,0.2);
    flex-shrink: 0;
  }

  .page-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--green), #34d399);
    transition: width 0.5s ease;
    width: 0%;
    border-radius: 0 3px 3px 0;
  }
</style>

<script>
  let _escAdded = false;

  function initFabs() {
    const fsBtn     = document.getElementById('fsBtn');
    const fsEnter   = document.getElementById('fsEnter');
    const fsExit    = document.getElementById('fsExit');
    const soundBtn  = document.getElementById('soundBtn');
    const soundOn   = document.getElementById('soundOn');
    const soundOff  = document.getElementById('soundOff');
    const infoBtn   = document.getElementById('infoBtn');
    const authorBtn = document.getElementById('authorBtn');
    const infoModal = document.getElementById('infoModal');
    const authorModal = document.getElementById('authorModal');
    const backdrop  = document.getElementById('fabBackdrop');
    const infoClose = document.getElementById('infoClose');
    const authorClose = document.getElementById('authorClose');

    if (!fsBtn) return;

    // --- Fullscreen ---
    function syncFsIcon() {
      const full = !!document.fullscreenElement;
      (fsEnter as HTMLElement).style.display = full ? 'none' : 'block';
      (fsExit as HTMLElement).style.display  = full ? 'block' : 'none';
    }

    fsBtn.onclick = () => {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(() => {});
      } else {
        document.exitFullscreen().catch(() => {});
      }
    };

    document.removeEventListener('fullscreenchange', syncFsIcon);
    document.addEventListener('fullscreenchange', syncFsIcon);
    syncFsIcon();

    // --- Sound ---
    function syncSoundIcon() {
      const enabled = localStorage.getItem('verbGameSounds') !== 'false';
      (soundOn as HTMLElement).style.display  = enabled ? 'block' : 'none';
      (soundOff as HTMLElement).style.display = enabled ? 'none'  : 'block';
    }

    soundBtn!.onclick = () => {
      const enabled = localStorage.getItem('verbGameSounds') !== 'false';
      localStorage.setItem('verbGameSounds', enabled ? 'false' : 'true');
      syncSoundIcon();
    };

    syncSoundIcon();

    // --- Modals ---
    function openModal(modal: HTMLElement) {
      closeAll();
      modal.classList.add('open');
      (backdrop as HTMLElement).classList.add('open');
    }

    function closeAll() {
      infoModal!.classList.remove('open');
      authorModal!.classList.remove('open');
      (backdrop as HTMLElement).classList.remove('open');
    }

    infoBtn!.onclick    = () => openModal(infoModal as HTMLElement);
    authorBtn!.onclick  = () => openModal(authorModal as HTMLElement);
    infoClose!.onclick  = closeAll;
    authorClose!.onclick = closeAll;
    backdrop!.onclick   = closeAll;

    if (!_escAdded) {
      _escAdded = true;
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          document.getElementById('infoModal')?.classList.remove('open');
          document.getElementById('authorModal')?.classList.remove('open');
          document.getElementById('fabBackdrop')?.classList.remove('open');
        }
      });
    }
  }

  function setYear() {
    const el = document.getElementById('footerYear');
    if (el) el.textContent = String(new Date().getFullYear());
  }

  initFabs();
  setYear();
  document.addEventListener('astro:page-load', () => { initFabs(); setYear(); });
</script>
