---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Memory Cards - Irregular Verbs">
  <div class="page">
    <header class="top-bar">
      <div class="top-row">
        <a href="/" class="back-btn">← Back</a>
        <h1>🃏 Memory Cards</h1>
        <div class="top-spacer"></div>
      </div>
      <div class="stats">
        <div class="stat-badge">Moves <strong id="moves">0</strong></div>
        <div class="stat-badge"><strong id="matches">0</strong>/<strong id="total">0</strong></div>
      </div>
    </header>

    <main class="game-area">
      <!-- Instructions -->
      <div class="panel center-panel" id="instructions">
        <div class="panel-icon">🃏</div>
        <h2>Find the Pairs</h2>
        <p>Flip cards to find matching verb form pairs!</p>
        <div class="diff-group">
          <p class="diff-label">Difficulty</p>
          <div class="diff-btns">
            <button class="diff-btn" data-pairs="6">Easy<br><small>6 pairs</small></button>
            <button class="diff-btn" data-pairs="8">Medium<br><small>8 pairs</small></button>
            <button class="diff-btn" data-pairs="10">Hard<br><small>10 pairs</small></button>
          </div>
        </div>
      </div>

      <!-- Cards -->
      <div class="cards-grid" id="cardsGrid" style="display:none"></div>

      <!-- Game Over -->
      <div class="panel center-panel" id="gameOver" style="display:none">
        <div class="panel-icon">🎉</div>
        <h2>Congratulations!</h2>
        <p class="big-result">Completed in <strong id="finalMoves">0</strong> moves!</p>
        <div class="save-record">
          <p class="save-label">Save your record</p>
          <div class="save-row">
            <input type="text" id="mcNameInput" class="save-name-input" placeholder="Your name…" maxlength="24" autocomplete="off">
            <button class="save-record-btn" id="mcSaveBtn">💾 Save</button>
          </div>
          <p class="save-done" id="mcSaveDone" style="display:none">✓ Saved!</p>
        </div>
        <button class="action-btn btn--cyan" id="restartBtn">Play Again</button>
      </div>
    </main>
  </div>
</Layout>

<script>
  import { loadData as fetchData } from '../utils/loadData.ts';
  import { playCorrect, playWrong } from '../utils/sounds.ts';
  import { saveScore, getPlayerName } from '../utils/scores.ts';
  import { saveUniverseScore, getUniverseSession } from '../utils/supabase.ts';

  let verbs: any[] = [];
  let settings: any = { forms: { present: true, past: true, participle: true, spanish: true } };
  let gameCards: any[] = [];
  let flipped: {card: any, el: HTMLElement}[] = [];
  let matchedPairs = 0, moves = 0, canFlip = true, totalPairs = 6;

  async function loadData() {
    try {
      ({ verbs, settings } = await fetchData());
    } catch (e) { console.error('loadData error:', e); }
  }

  function getAvailableForms() {
    const f = settings.forms;
    const forms: string[] = [];
    if (f.present) forms.push('present');
    if (f.past) forms.push('past');
    if (f.participle) forms.push('participle');
    if (f.spanish) forms.push('spanish');
    return forms.length >= 2 ? forms : ['present', 'past'];
  }

  function startGame(pairs: number) {
    totalPairs = pairs;
    const forms = getAvailableForms();
    if (forms.length < 2) { window.location.href = '/settings'; return; }

    const shuffled = [...forms].sort(() => Math.random() - 0.5);
    const [f1, f2] = shuffled;

    const selected = [...verbs].sort(() => Math.random() - 0.5).slice(0, pairs);
    gameCards = [];
    selected.forEach((verb, i) => {
      gameCards.push({ id: `${i}-a`, pairId: i, text: verb[f1] });
      gameCards.push({ id: `${i}-b`, pairId: i, text: verb[f2] });
    });
    gameCards.sort(() => Math.random() - 0.5);

    flipped = []; matchedPairs = 0; moves = 0; canFlip = true;

    (document.getElementById('moves') as HTMLElement).textContent = '0';
    (document.getElementById('matches') as HTMLElement).textContent = '0';
    (document.getElementById('total') as HTMLElement).textContent = String(totalPairs);

    renderCards();

    (document.getElementById('instructions') as HTMLElement).style.display = 'none';
    (document.getElementById('cardsGrid') as HTMLElement).style.display = 'grid';
    (document.getElementById('gameOver') as HTMLElement).style.display = 'none';
  }

  function renderCards() {
    const grid = document.getElementById('cardsGrid') as HTMLElement;
    grid.innerHTML = '';

    const cols = totalPairs <= 6 ? 4 : totalPairs <= 8 ? 4 : 5;
    const rows = Math.ceil((totalPairs * 2) / cols);
    grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
    grid.style.gridTemplateRows = `repeat(${rows}, 1fr)`;

    gameCards.forEach(card => {
      const el = document.createElement('div');
      el.className = 'mem-card';
      el.dataset.id = card.id;
      el.dataset.pairId = String(card.pairId);
      el.innerHTML = `
        <div class="card-inner">
          <div class="card-front">?</div>
          <div class="card-back">${card.text}</div>
        </div>
      `;
      el.addEventListener('click', () => flipCard(card, el));
      grid.appendChild(el);
    });
  }

  function flipCard(card: any, el: HTMLElement) {
    if (!canFlip || el.classList.contains('flipped') || el.classList.contains('matched') || flipped.length >= 2) return;
    el.classList.add('flipped');
    flipped.push({ card, el });
    if (flipped.length === 2) {
      moves++;
      (document.getElementById('moves') as HTMLElement).textContent = String(moves);
      checkMatch();
    }
  }

  function checkMatch() {
    canFlip = false;
    const [first, second] = flipped;
    if (first.card.pairId === second.card.pairId) {
      playCorrect();
      setTimeout(() => {
        first.el.classList.add('matched');
        second.el.classList.add('matched');
        flipped = [];
        matchedPairs++;
        (document.getElementById('matches') as HTMLElement).textContent = String(matchedPairs);
        canFlip = true;
        if (matchedPairs === totalPairs) setTimeout(endGame, 500);
      }, 400);
    } else {
      playWrong();
      setTimeout(() => {
        first.el.classList.remove('flipped');
        second.el.classList.remove('flipped');
        flipped = [];
        canFlip = true;
      }, 900);
    }
  }

  function endGame() {
    // Reset save widget
    (document.getElementById('mcNameInput') as HTMLInputElement).value = getPlayerName();
    (document.getElementById('mcSaveDone') as HTMLElement).style.display = 'none';
    (document.getElementById('mcSaveBtn') as HTMLButtonElement).disabled = false;
    (document.getElementById('cardsGrid') as HTMLElement).style.display = 'none';
    (document.getElementById('gameOver') as HTMLElement).style.display = 'flex';
    (document.getElementById('finalMoves') as HTMLElement).textContent = String(moves);

    if (getUniverseSession()) {
      saveUniverseScore('memory-cards', totalPairs * 1000 - moves, `${totalPairs} pairs in ${moves} moves`);
    }
  }

  function init() {
    if (!verbs.length) loadData();

    document.querySelectorAll<HTMLButtonElement>('.diff-btn').forEach(btn => {
      btn.onclick = () => startGame(parseInt(btn.dataset.pairs!));
    });

    document.getElementById('restartBtn')!.onclick = () => {
      (document.getElementById('gameOver') as HTMLElement).style.display = 'none';
      (document.getElementById('instructions') as HTMLElement).style.display = 'flex';
    };

    document.getElementById('mcSaveBtn')!.onclick = () => {
      const name = (document.getElementById('mcNameInput') as HTMLInputElement).value.trim();
      if (!name) return;
      saveScore('memory-cards', totalPairs * 1000 - moves, `${totalPairs} pairs in ${moves} moves`, name);
      (document.getElementById('mcSaveDone') as HTMLElement).style.display = 'block';
      (document.getElementById('mcSaveBtn') as HTMLButtonElement).disabled = true;
    };
  }

  document.addEventListener('astro:page-load', init);
  init();
</script>

<style>
  .page {
    min-height: 100dvh;
    background: linear-gradient(145deg, #06b6d4 0%, #3b82f6 100%);
    display: flex;
    flex-direction: column;
  }

  .top-bar {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 1.25rem 0.5rem;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .top-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .top-spacer {
    flex-shrink: 0;
    width: 80px;
  }

  h1 {
    color: white;
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    flex: 1;
    text-align: center;
    white-space: nowrap;
  }

  .stats { display: flex; gap: 0.5rem; }

  .stats .stat-badge { flex: 1; justify-content: center; }

  .game-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0.75rem 1.25rem 1.25rem;
    min-height: 0;
  }

  /* Panels */
  .panel {
    flex: 1;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: var(--r-xl);
    padding: 2rem 1.5rem;
  }

  .center-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    text-align: center;
  }

  .panel-icon { font-size: 3.5rem; line-height: 1; }
  .panel h2 { font-size: 1.8rem; font-weight: 800; color: white; }
  .panel p { color: rgba(255,255,255,0.85); font-size: 1rem; line-height: 1.6; font-weight: 500; }
  .big-result { font-size: 1.3rem !important; }

  .diff-group { width: 100%; max-width: 400px; }
  .diff-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.7);
    margin-bottom: 0.75rem;
  }

  .diff-btns {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
  }

  .diff-btn {
    flex: 1;
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 700;
    padding: 0.9rem 0.75rem;
    border: 2px solid rgba(255,255,255,0.4);
    border-radius: var(--r-md);
    background: rgba(255,255,255,0.2);
    color: white;
    cursor: pointer;
    transition: all var(--t);
    min-height: 66px;
    line-height: 1.3;
  }

  .diff-btn small { font-weight: 500; opacity: 0.8; font-size: 0.8rem; }
  .diff-btn:hover { background: rgba(255,255,255,0.35); border-color: white; transform: translateY(-3px); }

  .action-btn {
    font-family: var(--font);
    font-size: 1.1rem;
    font-weight: 700;
    border: none;
    border-radius: var(--r-md);
    padding: 0.85rem 2.5rem;
    cursor: pointer;
    transition: transform var(--t), box-shadow var(--t);
    min-height: 52px;
  }

  .action-btn:hover { transform: translateY(-3px); box-shadow: var(--sh-md); }
  .btn--cyan { background: white; color: #0e7490; }

  /* Cards grid */
  .cards-grid {
    flex: 1;
    display: grid;
    gap: 0.5rem;
    perspective: 1000px;
    min-height: 0;
    overflow: hidden;
  }

  :global(.mem-card) {
    cursor: pointer;
    position: relative;
    border-radius: var(--r-md);
    transition: transform 0.2s;
    min-height: 0;
  }

  :global(.mem-card:hover:not(.matched)) { transform: scale(1.02); }

  :global(.card-inner) {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    min-height: 0;
  }

  :global(.mem-card.flipped .card-inner),
  :global(.mem-card.matched .card-inner) { transform: rotateY(180deg); }

  :global(.card-front),
  :global(.card-back) {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--r-md);
    font-weight: 800;
  }

  :global(.card-front) {
    background: linear-gradient(135deg, #0ea5e9, #3b82f6);
    color: rgba(255,255,255,0.6);
    font-size: clamp(1rem, 3vw, 2rem);
    box-shadow: 0 4px 14px rgba(0,0,0,0.15);
  }

  :global(.card-back) {
    background: white;
    color: #0e7490;
    font-size: clamp(0.65rem, 2vw, 1rem);
    transform: rotateY(180deg);
    padding: 0.35rem;
    word-break: break-word;
    text-align: center;
    box-shadow: 0 4px 14px rgba(0,0,0,0.12);
    overflow: hidden;
  }

  :global(.mem-card.matched .card-back) {
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
  }

  @media (min-width: 600px) {
    .top-bar { flex-direction: row; align-items: center; padding: 0.85rem 1.75rem; gap: 0.75rem; }
    .top-row { flex: 1; }
    .stats { flex-shrink: 0; }
    .stats .stat-badge { flex: none; }
    h1 { font-size: 1.5rem; white-space: normal; }
    .game-area { padding: 1rem 1.75rem 1.5rem; }
    .cards-grid { gap: 0.75rem; }
    :global(.card-back) { font-size: 1.1rem; }
  }

  @media (min-width: 1024px) {
    .game-area { padding: 1.25rem 2.5rem 2rem; }
    .cards-grid { gap: 1rem; }
    :global(.card-back) { font-size: 1.2rem; }
  }
</style>
