---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quick Match - Irregular Verbs" bodyClass="qm-body">
  <div class="page">
    <header class="top-bar">
      <div class="top-row">
        <a href="/" class="back-btn">← Back</a>
        <h1>🎯 Quick Match</h1>
        <div class="top-spacer"></div>
      </div>
      <div class="stats" id="statsRow">
        <div class="stat-badge" id="scoreBadge">Score <strong id="score">0</strong></div>
        <div class="stat-badge" id="streakBadge">🔥 <strong id="streak">0</strong></div>
        <div class="stat-badge" id="timerBadge" style="display:none">⏱️ <strong id="timerDisplay">5:00</strong></div>
        <div class="stat-badge best-badge" id="bestBadge">Best <strong id="best">0</strong></div>
      </div>
    </header>

    <!-- Lives bar -->
    <div class="lives-bar" id="livesBar">
      <div class="lives-hearts" id="livesHearts"></div>
      <div class="bonus-msg" id="bonusMsg"></div>
    </div>

    <!-- Mode selector overlay -->
    <div class="mode-select" id="modeSelect">
      <p class="mode-title">Choose a mode</p>
      <div class="mode-cards">
        <button class="mode-card" data-mode="endless">
          <span class="mode-icon">♾️</span>
          <strong>Endless</strong>
          <span>No lives · No timer<br>Score forever</span>
        </button>
        <button class="mode-card" data-mode="survival">
          <span class="mode-icon">❤️</span>
          <strong>Survival</strong>
          <span>3 lives · +1 every<br>10 streak</span>
        </button>
        <button class="mode-card" data-mode="rush">
          <span class="mode-icon">⏱️</span>
          <strong>Rush</strong>
          <span>Timer per question<br>5 min → 10 sec</span>
        </button>
      </div>
    </div>

    <main class="game-area" id="gameArea" style="display:none">
      <div class="question-card">
        <p class="q-label" id="questionLabel">Find the PRESENT form of:</p>
        <p class="q-word" id="questionWord">—</p>
        <p class="q-hint" id="hint"></p>
        <!-- Rush timer bar -->
        <div class="timer-bar-wrap" id="timerBarWrap" style="display:none">
          <div class="timer-bar" id="timerBar"></div>
        </div>
      </div>

      <div class="options-grid" id="optionsGrid"></div>

      <div class="result-msg" id="resultMessage"></div>
    </main>

    <!-- Game Over panel -->
    <div class="gameover-overlay" id="gameOverPanel" style="display:none">
      <div class="gameover-card">
        <div class="go-icon" id="goIcon">💔</div>
        <h2 id="goTitle">Game Over</h2>
        <p class="go-stat">Score: <strong id="goScore">0</strong></p>
        <p class="go-stat">Best streak: <strong id="goStreak">0</strong></p>
        <p class="go-stat">Questions: <strong id="goTotal">0</strong></p>
        <div class="save-record" id="goSaveWidget">
          <p class="save-label">Save your record</p>
          <div class="save-row">
            <input type="text" id="goNameInput" class="save-name-input" placeholder="Your name…" maxlength="24" autocomplete="off">
            <button class="save-record-btn" id="goSaveBtn">💾 Save</button>
          </div>
          <p class="save-done" id="goSaveDone" style="display:none">✓ Saved!</p>
        </div>
        <div class="go-btns">
          <button class="go-btn go-btn--play" id="goPlayAgain">Play Again</button>
          <button class="go-btn go-btn--change" id="goChangeMode">Change Mode</button>
          <a href="/scores" class="go-btn go-btn--scores">🏆 Records</a>
        </div>
      </div>
    </div>

    <div class="page-progress">
      <div class="page-progress-fill" id="progressFill"></div>
    </div>
  </div>
</Layout>

<script>
  import { loadData as fetchData } from '../utils/loadData.ts';
  import { playCorrect, playWrong } from '../utils/sounds.ts';
  import { saveScore, getPlayerName } from '../utils/scores.ts';

  // Rush: time per question in seconds per level (every 10 correct = next level)
  const RUSH_TIMES = [300, 240, 180, 120, 90, 60, 45, 30, 20, 15, 10];
  const MAX_LIVES = 3;
  const BONUS_EVERY = 10;

  type GameMode = 'endless' | 'survival' | 'rush';

  let verbs: any[] = [];
  let settings: any = { forms: { present: true, past: true, participle: true, spanish: true } };
  let currentVerb: any = null;
  let currentQuestion: any = null;
  let gameMode: GameMode = 'survival';

  let score = 0, streak = 0, maxStreak = 0, totalQuestions = 0, lives = MAX_LIVES;
  let best = 0;

  // Rush timer state
  let rushTimer: ReturnType<typeof setInterval> | null = null;
  let rushSecondsLeft = 300;
  let rushTotalSeconds = 300;

  // ── Best score key per mode ──
  function bestKey() { return `qm_best_${gameMode}`; }

  function updateBest() {
    if (score > best) { best = score; localStorage.setItem(bestKey(), String(best)); }
    (document.getElementById('best') as HTMLElement).textContent = String(best);
  }

  // ── Lives ──
  function renderLives() {
    const el = document.getElementById('livesHearts') as HTMLElement;
    el.innerHTML =
      Array.from({ length: Math.max(lives, 0) }, () => '<span class="heart">❤️</span>').join('') +
      Array.from({ length: Math.max(MAX_LIVES - lives, 0) }, () => '<span class="heart lost">🖤</span>').join('');
  }

  function showBonus() {
    const el = document.getElementById('bonusMsg') as HTMLElement;
    el.textContent = '+1 vida 🎉';
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 2000);
  }

  // ── Rush timer ──
  function getRushTimeForLevel(): number {
    const level = Math.min(Math.floor(score / 10), RUSH_TIMES.length - 1);
    return RUSH_TIMES[level];
  }

  function formatTime(s: number): string {
    if (s >= 60) return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
    return `${s}s`;
  }

  function startRushTimer() {
    stopRushTimer();
    rushTotalSeconds = getRushTimeForLevel();
    rushSecondsLeft = rushTotalSeconds;
    updateTimerUI();

    rushTimer = setInterval(() => {
      rushSecondsLeft--;
      updateTimerUI();
      if (rushSecondsLeft <= 0) {
        stopRushTimer();
        onTimerExpired();
      }
    }, 1000);
  }

  function stopRushTimer() {
    if (rushTimer !== null) { clearInterval(rushTimer); rushTimer = null; }
  }

  function updateTimerUI() {
    const pct = rushSecondsLeft / rushTotalSeconds;
    const bar = document.getElementById('timerBar') as HTMLElement;
    const display = document.getElementById('timerDisplay') as HTMLElement;

    display.textContent = formatTime(rushSecondsLeft);
    bar.style.width = (pct * 100) + '%';

    // Color transitions
    bar.className = 'timer-bar';
    if (pct <= 0.15) bar.classList.add('danger');
    else if (pct <= 0.35) bar.classList.add('warning');

    // Pulse urgency on badge
    const badge = document.getElementById('timerBadge') as HTMLElement;
    badge.className = 'stat-badge';
    if (pct <= 0.15) badge.classList.add('timer-danger');
    else if (pct <= 0.35) badge.classList.add('timer-warning');
  }

  function onTimerExpired() {
    const allBtns = document.querySelectorAll<HTMLButtonElement>('.opt-btn');
    allBtns.forEach(b => b.disabled = true);
    allBtns.forEach(b => { if (b.textContent === currentQuestion.correct) b.classList.add('correct'); });

    const msg = document.getElementById('resultMessage') as HTMLElement;
    msg.textContent = `⏰ Time's up! — ${currentQuestion.correct}`;
    msg.className = 'result-msg is-wrong';

    playWrong();
    lives--;
    streak = 0;
    renderLives();
    (document.getElementById('streak') as HTMLElement).textContent = '0';
    document.getElementById('livesHearts')!.classList.add('shake');
    setTimeout(() => document.getElementById('livesHearts')!.classList.remove('shake'), 500);

    if (lives <= 0) {
      setTimeout(gameOver, 1000);
    } else {
      setTimeout(generateQuestion, 1800);
    }
  }

  // ── Setup UI per mode ──
  function applyModeUI() {
    const livesBar   = document.getElementById('livesBar') as HTMLElement;
    const timerBadge = document.getElementById('timerBadge') as HTMLElement;
    const streakBadge = document.getElementById('streakBadge') as HTMLElement;
    const bestBadge  = document.getElementById('bestBadge') as HTMLElement;
    const timerWrap  = document.getElementById('timerBarWrap') as HTMLElement;

    livesBar.style.display   = gameMode === 'endless' ? 'none' : '';
    timerBadge.style.display = gameMode === 'rush' ? '' : 'none';
    timerWrap.style.display  = gameMode === 'rush' ? '' : 'none';
    bestBadge.style.display  = gameMode === 'endless' ? 'none' : '';
    streakBadge.style.display = '';
  }

  // ── Data loading ──
  async function loadData() {
    try {
      ({ verbs, settings } = await fetchData());
      generateQuestion();
    } catch (e) { console.error('loadData error:', e); }
  }

  function getAvailableForms() {
    const f = settings.forms;
    const forms = [];
    if (f.present) forms.push('present');
    if (f.past) forms.push('past');
    if (f.participle) forms.push('participle');
    if (f.spanish) forms.push('spanish');
    return forms.length >= 2 ? forms : ['present', 'past', 'participle'];
  }

  const LABELS: Record<string, string> = {
    present: 'PRESENT', past: 'PAST', participle: 'PARTICIPLE', spanish: 'SPANISH'
  };

  function generateQuestion() {
    const forms = getAvailableForms();
    if (forms.length < 2) { window.location.href = '/settings'; return; }

    currentVerb = verbs[Math.floor(Math.random() * verbs.length)];
    const showForm = forms[Math.floor(Math.random() * forms.length)];
    const askForms = forms.filter(f => f !== showForm);
    const askForm = askForms[Math.floor(Math.random() * askForms.length)];

    currentQuestion = { show: showForm, ask: askForm, correct: currentVerb[askForm] };

    (document.getElementById('questionLabel') as HTMLElement).textContent =
      `Find the ${LABELS[askForm]} form of:`;
    (document.getElementById('questionWord') as HTMLElement).textContent = currentVerb[showForm];

    const hintEl = document.getElementById('hint') as HTMLElement;
    hintEl.textContent = (showForm !== 'spanish' && askForm !== 'spanish' && settings.forms.spanish)
      ? `(${currentVerb.spanish})` : '';

    generateOptions();
    const msg = document.getElementById('resultMessage') as HTMLElement;
    msg.textContent = '';
    msg.className = 'result-msg';

    if (gameMode === 'rush') startRushTimer();
  }

  function generateOptions() {
    const options = [currentQuestion.correct];
    while (options.length < 4) {
      const rand = verbs[Math.floor(Math.random() * verbs.length)][currentQuestion.ask];
      if (!options.includes(rand)) options.push(rand);
    }
    options.sort(() => Math.random() - 0.5);

    const grid = document.getElementById('optionsGrid') as HTMLElement;
    grid.innerHTML = '';
    options.forEach(opt => {
      const btn = document.createElement('button');
      btn.className = 'opt-btn';
      btn.textContent = opt;
      btn.onclick = () => checkAnswer(opt, btn);
      grid.appendChild(btn);
    });
  }

  function checkAnswer(selected: string, btn: HTMLButtonElement) {
    if (gameMode === 'rush') stopRushTimer();
    totalQuestions++;
    const allBtns = document.querySelectorAll<HTMLButtonElement>('.opt-btn');
    allBtns.forEach(b => b.disabled = true);

    const msg = document.getElementById('resultMessage') as HTMLElement;

    if (selected === currentQuestion.correct) {
      playCorrect();
      btn.classList.add('correct');
      score++;
      streak++;
      if (streak > maxStreak) maxStreak = streak;

      if (gameMode !== 'endless' && streak % BONUS_EVERY === 0) {
        lives++;
        renderLives();
        showBonus();
        msg.textContent = `✓ Correct! +1 vida bonus 🎉`;
      } else {
        msg.textContent = gameMode === 'rush'
          ? `✓ Correct! Next: ${formatTime(getRushTimeForLevel())} ⏱️`
          : `✓ Correct! 🔥 ${streak}`;
      }
      msg.className = 'result-msg is-correct';

      (document.getElementById('score') as HTMLElement).textContent = String(score);
      (document.getElementById('streak') as HTMLElement).textContent = String(streak);
      updateBest();
      const acc = (score / totalQuestions) * 100;
      (document.getElementById('progressFill') as HTMLElement).style.width = acc + '%';
      setTimeout(generateQuestion, 1400);

    } else {
      playWrong();
      btn.classList.add('wrong');
      allBtns.forEach(b => { if (b.textContent === currentQuestion.correct) b.classList.add('correct'); });

      msg.textContent = `✗ Wrong — ${currentQuestion.correct}`;
      msg.className = 'result-msg is-wrong';
      (document.getElementById('streak') as HTMLElement).textContent = '0';
      streak = 0;

      if (gameMode !== 'endless') {
        lives--;
        renderLives();
        document.getElementById('livesHearts')!.classList.add('shake');
        setTimeout(() => document.getElementById('livesHearts')!.classList.remove('shake'), 500);

        if (lives <= 0) {
          setTimeout(gameOver, 1000);
          return;
        }
      }

      (document.getElementById('score') as HTMLElement).textContent = String(score);
      updateBest();
      const acc = (score / totalQuestions) * 100;
      (document.getElementById('progressFill') as HTMLElement).style.width = acc + '%';
      setTimeout(generateQuestion, 1800);
    }
  }

  function gameOver() {
    (document.getElementById('goScore') as HTMLElement).textContent = String(score);
    (document.getElementById('goStreak') as HTMLElement).textContent = String(maxStreak);
    (document.getElementById('goTotal') as HTMLElement).textContent = String(totalQuestions);

    const icons: Record<GameMode, string> = { endless: '🏁', survival: '💔', rush: '⏰' };
    const titles: Record<GameMode, string> = { endless: 'Session ended', survival: 'Game Over', rush: 'Time\'s up!' };
    (document.getElementById('goIcon') as HTMLElement).textContent = icons[gameMode];
    (document.getElementById('goTitle') as HTMLElement).textContent = titles[gameMode];

    (document.getElementById('goNameInput') as HTMLInputElement).value = getPlayerName();
    (document.getElementById('goSaveDone') as HTMLElement).style.display = 'none';
    (document.getElementById('goSaveBtn') as HTMLButtonElement).disabled = false;
    (document.getElementById('gameOverPanel') as HTMLElement).style.display = 'flex';
  }

  document.getElementById('goSaveBtn')!.addEventListener('click', () => {
    const name = (document.getElementById('goNameInput') as HTMLInputElement).value.trim();
    if (!name) return;
    const modeLabel = gameMode === 'rush' ? 'rush' : gameMode === 'endless' ? 'endless' : 'quick-match';
    saveScore(modeLabel, score, `${score} pts · ${maxStreak} streak`, name);
    (document.getElementById('goSaveDone') as HTMLElement).style.display = 'block';
    (document.getElementById('goSaveBtn') as HTMLButtonElement).disabled = true;
  });

  function startGame(mode: GameMode) {
    gameMode = mode;
    best = parseInt(localStorage.getItem(bestKey()) ?? '0', 10);
    score = 0; streak = 0; maxStreak = 0; totalQuestions = 0;
    lives = MAX_LIVES;

    (document.getElementById('score') as HTMLElement).textContent = '0';
    (document.getElementById('streak') as HTMLElement).textContent = '0';
    (document.getElementById('best') as HTMLElement).textContent = String(best);
    (document.getElementById('progressFill') as HTMLElement).style.width = '0%';
    (document.getElementById('gameOverPanel') as HTMLElement).style.display = 'none';
    (document.getElementById('modeSelect') as HTMLElement).style.display = 'none';
    (document.getElementById('gameArea') as HTMLElement).style.display = 'flex';

    applyModeUI();
    if (gameMode !== 'endless') renderLives();

    if (verbs.length) { generateQuestion(); } else { loadData(); }
  }

  function showModeSelect() {
    stopRushTimer();
    (document.getElementById('gameOverPanel') as HTMLElement).style.display = 'none';
    (document.getElementById('gameArea') as HTMLElement).style.display = 'none';
    (document.getElementById('modeSelect') as HTMLElement).style.display = 'flex';
  }

  // Mode card buttons
  document.querySelectorAll<HTMLButtonElement>('.mode-card').forEach(btn => {
    btn.addEventListener('click', () => startGame(btn.dataset.mode as GameMode));
  });

  document.getElementById('goPlayAgain')!.addEventListener('click', () => startGame(gameMode));
  document.getElementById('goChangeMode')!.addEventListener('click', showModeSelect);

  function init() {
    stopRushTimer();
    showModeSelect();
    if (!verbs.length) loadData();
  }

  document.addEventListener('astro:page-load', init);
  init();
</script>

<style>
  /* ── Lives bar ── */
  .lives-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.2rem 1.25rem 0.5rem;
    flex-shrink: 0;
    position: relative;
  }

  .lives-hearts {
    display: flex;
    gap: 0.35rem;
    align-items: center;
  }

  :global(.heart) { font-size: 1.5rem; transition: transform 0.2s; }
  :global(.heart.lost) { filter: grayscale(1); opacity: 0.4; }

  :global(.lives-hearts.shake) {
    animation: shakeH 0.45s ease;
  }

  @keyframes shakeH {
    0%,100% { transform: translateX(0); }
    20%      { transform: translateX(-8px); }
    40%      { transform: translateX(8px); }
    60%      { transform: translateX(-6px); }
    80%      { transform: translateX(6px); }
  }

  .bonus-msg {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%) scale(0.6);
    background: #10b981;
    color: white;
    font-size: 0.85rem;
    font-weight: 800;
    padding: 0.3rem 0.8rem;
    border-radius: var(--r-sm);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s, transform 0.2s;
    white-space: nowrap;
  }

  :global(.bonus-msg.show) {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  /* ── Mode selector ── */
  .mode-select {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1.25rem;
    gap: 1.25rem;
  }

  .mode-title {
    color: rgba(255,255,255,0.85);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .mode-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    max-width: 380px;
  }

  .mode-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    background: rgba(255,255,255,0.14);
    border: 1.5px solid rgba(255,255,255,0.22);
    border-radius: var(--r-lg);
    cursor: pointer;
    text-align: left;
    color: white;
    transition: background 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .mode-card:hover {
    background: rgba(255,255,255,0.24);
    border-color: rgba(255,255,255,0.5);
    transform: translateY(-2px);
  }

  .mode-card:active { transform: scale(0.98); }

  .mode-icon { font-size: 2rem; line-height: 1; flex-shrink: 0; }

  .mode-card strong {
    display: block;
    font-size: 1.05rem;
    font-weight: 800;
    margin-bottom: 0.15rem;
  }

  .mode-card span {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.72);
    font-weight: 500;
    line-height: 1.4;
  }

  /* ── Timer bar ── */
  .timer-bar-wrap {
    margin-top: 1rem;
    height: 6px;
    background: rgba(255,255,255,0.18);
    border-radius: 3px;
    overflow: hidden;
  }

  .timer-bar {
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, #10b981, #34d399);
    border-radius: 3px;
    transition: width 0.9s linear, background 0.4s ease;
  }

  .timer-bar.warning {
    background: linear-gradient(90deg, #f59e0b, #fbbf24);
  }

  .timer-bar.danger {
    background: linear-gradient(90deg, #ef4444, #f87171);
    animation: timerPulse 0.6s ease infinite alternate;
  }

  @keyframes timerPulse {
    from { opacity: 0.7; }
    to   { opacity: 1; }
  }

  /* Timer badge urgency */
  :global(.stat-badge.timer-warning) {
    background: rgba(245,158,11,0.35) !important;
  }
  :global(.stat-badge.timer-danger) {
    background: rgba(239,68,68,0.45) !important;
    animation: timerPulse 0.6s ease infinite alternate;
  }

  /* ── Game Over overlay ── */
  .gameover-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(30, 10, 60, 0.82);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .gameover-card {
    background: white;
    border-radius: var(--r-xl);
    padding: 2.5rem 2rem 2rem;
    max-width: 360px;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    box-shadow: var(--sh-lg);
  }

  .go-icon { font-size: 3.5rem; line-height: 1; }

  .gameover-card h2 {
    font-size: 1.8rem;
    font-weight: 900;
    color: #1e1b4b;
    letter-spacing: -0.03em;
  }

  .go-stat {
    font-size: 1rem;
    color: #6b7280;
    font-weight: 500;
  }

  .go-stat strong { color: #1e1b4b; font-weight: 800; font-size: 1.1rem; }

  .save-record {
    width: 100%;
    background: #f9fafb;
    border: 1.5px solid #e5e7eb;
    border-radius: var(--r-md);
    padding: 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .save-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
  }

  .save-row { display: flex; gap: 0.5rem; }

  .save-name-input {
    flex: 1;
    font-family: var(--font);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.55rem 0.75rem;
    border: 1.5px solid #e5e7eb;
    border-radius: var(--r-sm);
    outline: none;
    color: #1e1b4b;
    transition: border-color var(--t);
    min-height: 40px;
  }

  .save-name-input:focus { border-color: #667eea; }

  .save-record-btn {
    font-family: var(--font);
    font-size: 0.88rem;
    font-weight: 700;
    padding: 0.55rem 1rem;
    border: none;
    border-radius: var(--r-sm);
    background: #667eea;
    color: white;
    cursor: pointer;
    transition: all var(--t);
    white-space: nowrap;
    min-height: 40px;
  }

  .save-record-btn:hover { background: #4f46e5; }
  .save-record-btn:disabled { opacity: 0.5; cursor: default; }

  .save-done { font-size: 0.85rem; font-weight: 700; color: #10b981; }

  .go-btns {
    display: flex;
    flex-wrap: wrap;
