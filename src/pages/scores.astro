---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Records - Irregular Verbs">
  <div class="page" id="scores-page">
    <header class="top-bar">
      <a href="/" class="back-btn">← Back</a>
      <h1>🏆 Records</h1>
      <div style="width:80px"></div>
    </header>

    <main class="records-area">
      <div id="noName" class="name-prompt" style="display:none">
        <p>Set your player name in <a href="/settings">Settings ⚙️</a> to start saving records.</p>
      </div>

      <div id="recordsGrid" class="records-grid"></div>
    </main>
  </div>
</Layout>

<script>
  import { getScores, getPlayerName } from '../utils/scores.ts';

  const GAMES = [
    { id: 'quick-match',     icon: '🎯', name: 'Quick Match',      unit: 'pts',     higherBetter: true  },
    { id: 'speed-challenge', icon: '⚡', name: 'Speed Challenge',  unit: 'pairs',   higherBetter: true  },
    { id: 'type-master',     icon: '⌨️', name: 'Type Master',      unit: 'correct', higherBetter: true  },
    { id: 'memory-cards',    icon: '🃏', name: 'Memory Cards',     unit: 'moves',   higherBetter: false },
    { id: 'practice',        icon: '♾️', name: 'Practice',         unit: '%',       higherBetter: true  },
  ] as const;

  function formatDate(iso: string) {
    const d = new Date(iso);
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  function render() {
    const name = getPlayerName();
    const noName = document.getElementById('noName')!;
    const grid   = document.getElementById('recordsGrid')!;

    if (!name) { noName.style.display = 'block'; grid.innerHTML = ''; return; }
    noName.style.display = 'none';

    grid.innerHTML = GAMES.map(g => {
      const entries = getScores(g.id as any);
      const rows = entries.length
        ? entries.map((e, i) => `
            <tr class="${i === 0 ? 'top-row' : ''}">
              <td class="rank">${i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : `#${i+1}`}</td>
              <td class="entry-name">${e.name}</td>
              <td class="entry-score">${e.label}</td>
              <td class="entry-date">${formatDate(e.date)}</td>
            </tr>`).join('')
        : `<tr><td colspan="4" class="empty">No records yet — go play!</td></tr>`;

      return `
        <div class="game-card">
          <div class="game-header">
            <span class="game-icon">${g.icon}</span>
            <span class="game-name">${g.name}</span>
          </div>
          <table class="score-table">
            <thead>
              <tr>
                <th>#</th><th>Name</th><th>Score</th><th>Date</th>
              </tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        </div>`;
    }).join('');
  }

  render();
  document.addEventListener('astro:page-load', render);
</script>

<style>
  /* Scoped page-level styles */
  .page {
    min-height: 100dvh;
    background: linear-gradient(145deg, #f59e0b 0%, #b45309 100%);
    display: flex;
    flex-direction: column;
  }

  .top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.25rem;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  h1 {
    color: white;
    font-size: 1.25rem;
    font-weight: 800;
    flex: 1;
    text-align: center;
  }

  .records-area {
    flex: 1;
    padding: 0.75rem 1.25rem 5rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 760px;
    margin: 0 auto;
    width: 100%;
  }

  .name-prompt {
    background: rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: var(--r-lg);
    padding: 1.25rem 1.5rem;
    color: white;
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
  }

  .name-prompt a { color: white; font-weight: 800; }

  .records-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 600px) {
    .top-bar { padding: 1rem 1.75rem; }
    h1 { font-size: 1.5rem; }
    .records-area { padding: 1rem 1.75rem 5rem; }
  }
</style>

<!-- Dynamic content styles must be global (innerHTML doesn't get scoped attrs) -->
<style is:global>
  #scores-page .game-card {
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: var(--r-xl);
    overflow: hidden;
  }

  #scores-page .game-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.25rem;
    background: rgba(255,255,255,0.12);
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }

  #scores-page .game-icon { font-size: 1.2rem; }

  #scores-page .game-name {
    font-size: 1rem;
    font-weight: 800;
    color: white;
  }

  #scores-page .score-table {
    width: 100%;
    border-collapse: collapse;
  }

  #scores-page .score-table thead tr {
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }

  #scores-page .score-table th {
    padding: 0.5rem 1rem;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.55);
    text-align: left;
  }

  #scores-page .score-table td {
    padding: 0.6rem 1rem;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  #scores-page .score-table tbody tr:last-child td { border-bottom: none; }

  #scores-page .top-row td {
    background: rgba(255,255,255,0.1);
    color: white;
    font-weight: 700;
  }

  #scores-page .rank { font-size: 1rem; width: 2.5rem; }
  #scores-page .entry-name { font-weight: 700; color: white; }
  #scores-page .entry-score { font-weight: 700; color: #fde68a; }
  #scores-page .entry-date { font-size: 0.75rem; color: rgba(255,255,255,0.5); }

  #scores-page .empty {
    text-align: center;
    color: rgba(255,255,255,0.45);
    font-style: italic;
    padding: 1rem !important;
  }
</style>
