---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Speed Challenge - Irregular Verbs">
  <div class="page">
    <header class="top-bar">
      <a href="/" class="back-btn">← Back</a>
      <h1>⚡ Speed Challenge</h1>
      <div class="timer-badge" id="timer">60s</div>
    </header>

    <main class="game-area">
      <!-- Instructions -->
      <div class="panel center-panel" id="instructions">
        <div class="panel-icon">⚡</div>
        <h2>How to Play</h2>
        <p>Click one word from each column to match verb pairs.<br>Get as many as you can in <strong>60 seconds</strong>!</p>
        <button class="action-btn btn--pink" id="startBtn">Start Game</button>
      </div>

      <!-- Game -->
      <div class="game-play" id="gameArea" style="display:none">
        <div class="score-strip">
          Matches: <strong id="matches">0</strong>
        </div>
        <div class="columns-wrap">
          <div class="verb-col">
            <h3 id="leftLabel">Present</h3>
            <div class="verb-list" id="leftCol"></div>
          </div>
          <div class="divider"></div>
          <div class="verb-col">
            <h3 id="rightLabel">Past</h3>
            <div class="verb-list" id="rightCol"></div>
          </div>
        </div>
      </div>

      <!-- Game Over -->
      <div class="panel center-panel" id="gameOver" style="display:none">
        <div class="panel-icon">🎉</div>
        <h2>Time's Up!</h2>
        <p class="big-result">You matched <strong id="finalScore">0</strong> pairs!</p>
        <p class="best-result">Best: <strong id="bestScore">0</strong></p>
        <div class="save-record">
          <p class="save-label">Save your record</p>
          <div class="save-row">
            <input type="text" id="scNameInput" class="save-name-input" placeholder="Your name…" maxlength="24" autocomplete="off">
            <button class="save-record-btn" id="scSaveBtn">💾 Save</button>
          </div>
          <p class="save-done" id="scSaveDone" style="display:none">✓ Saved!</p>
        </div>
        <button class="action-btn btn--pink" id="restartBtn">Play Again</button>
      </div>
    </main>
  </div>
</Layout>

<script>
  import { loadData as fetchData } from '../utils/loadData.ts';
  import { playCorrect, playWrong } from '../utils/sounds.ts';
  import { saveScore, getPlayerName } from '../utils/scores.ts';
  import { saveUniverseScore, getUniverseSession } from '../utils/supabase.ts';

  const PAIR_COLORS = [
    ['#6366f1','#4338ca'],
    ['#f59e0b','#b45309'],
    ['#06b6d4','#0e7490'],
    ['#8b5cf6','#6d28d9'],
    ['#ef4444','#b91c1c'],
    ['#10b981','#047857'],
    ['#f97316','#c2410c'],
    ['#ec4899','#be185d'],
    ['#84cc16','#4d7c0f'],
    ['#14b8a6','#0f766e'],
  ];

  let verbs: any[] = [];
  let settings: any = { forms: { present: true, past: true, participle: true, spanish: true } };
  let gameVerbs: any[] = [];
  let selectedLeft: string|null = null;
  let selectedRight: string|null = null;
  let matches = 0;
  let timeLeft = 60;
  let timerInterval: ReturnType<typeof setInterval>|null = null;
  let best = parseInt(localStorage.getItem('sc_best') ?? '0', 10);

  async function loadData() {
    try {
      ({ verbs, settings } = await fetchData());
    } catch (e) { console.error('loadData error:', e); }
  }

  function getAvailableForms() {
    const f = settings.forms;
    const forms = [];
    if (f.present) forms.push('present');
    if (f.past) forms.push('past');
    if (f.participle) forms.push('participle');
    if (f.spanish) forms.push('spanish');
    return forms.length >= 2 ? forms : ['present', 'past'];
  }

  const LABEL: Record<string,string> = { present:'Present', past:'Past', participle:'Participle', spanish:'Spanish' };

  function startGame() {
    const forms = getAvailableForms();
    if (forms.length < 2) { window.location.href = '/settings'; return; }

    const shuffled = [...forms].sort(() => Math.random() - 0.5);
    const lf = shuffled[0], rf = shuffled[1];

    (document.getElementById('leftLabel') as HTMLElement).textContent = LABEL[lf];
    (document.getElementById('rightLabel') as HTMLElement).textContent = LABEL[rf];

    gameVerbs = [...verbs].sort(() => Math.random() - 0.5).slice(0, 10).map((v, i) => ({
      id: String(i), left: v[lf], right: v[rf]
    }));

    renderColumns();

    (document.getElementById('instructions') as HTMLElement).style.display = 'none';
    (document.getElementById('gameArea') as HTMLElement).style.display = 'flex';
    (document.getElementById('gameOver') as HTMLElement).style.display = 'none';

    matches = 0; timeLeft = 60; selectedLeft = null; selectedRight = null;
    (document.getElementById('matches') as HTMLElement).textContent = '0';
    (document.getElementById('timer') as HTMLElement).textContent = '60s';
    (document.getElementById('timer') as HTMLElement).classList.remove('warning');

    if (timerInterval) clearInterval(timerInterval);
    timerInterval = setInterval(tick, 1000);
  }

  function renderColumns() {
    const lc = document.getElementById('leftCol') as HTMLElement;
    const rc = document.getElementById('rightCol') as HTMLElement;
    lc.innerHTML = ''; rc.innerHTML = '';

    const rightShuffled = [...gameVerbs].sort(() => Math.random() - 0.5);

    gameVerbs.forEach(v => {
      const btn = document.createElement('button');
      btn.className = 'vb-btn';
      btn.textContent = v.left;
      btn.dataset.id = v.id;
      btn.onclick = () => selectLeft(v.id, btn);
      lc.appendChild(btn);
    });

    rightShuffled.forEach(v => {
      const btn = document.createElement('button');
      btn.className = 'vb-btn';
      btn.textContent = v.right;
      btn.dataset.id = v.id;
      btn.onclick = () => selectRight(v.id, btn);
      rc.appendChild(btn);
    });
  }

  function selectLeft(id: string, btn: HTMLButtonElement) {
    if (btn.classList.contains('matched')) return;
    document.querySelectorAll('#leftCol .vb-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    selectedLeft = id;
    checkMatch();
  }

  function selectRight(id: string, btn: HTMLButtonElement) {
    if (btn.classList.contains('matched')) return;
    document.querySelectorAll('#rightCol .vb-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    selectedRight = id;
    checkMatch();
  }

  function checkMatch() {
    if (selectedLeft === null || selectedRight === null) return;
    if (selectedLeft === selectedRight) {
      playCorrect();
      const colorIdx = parseInt(selectedLeft!) % PAIR_COLORS.length;
      const [c1, c2] = PAIR_COLORS[colorIdx];
      document.querySelectorAll<HTMLButtonElement>(`.vb-btn[data-id="${selectedLeft}"]`).forEach(b => {
        b.classList.remove('selected');
        b.classList.add('matched');
        b.style.background = `linear-gradient(135deg, ${c1}, ${c2})`;
        b.style.borderColor = 'transparent';
        b.disabled = true;
      });
      matches++;
      (document.getElementById('matches') as HTMLElement).textContent = String(matches);
      if (matches === gameVerbs.length) endGame();
    } else {
      playWrong();
      document.querySelectorAll<HTMLButtonElement>('.vb-btn.selected').forEach(b => {
        b.classList.add('wrong');
        setTimeout(() => b.classList.remove('wrong', 'selected'), 500);
      });
    }
    selectedLeft = null; selectedRight = null;
  }

  function tick() {
    timeLeft--;
    const t = document.getElementById('timer') as HTMLElement;
    t.textContent = timeLeft + 's';
    if (timeLeft <= 10) t.classList.add('warning');
    if (timeLeft <= 0) endGame();
  }

  function endGame() {
    if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
    if (matches > best) {
      best = matches;
      localStorage.setItem('sc_best', String(best));
    }
    // Reset save widget
    (document.getElementById('scNameInput') as HTMLInputElement).value = getPlayerName();
    (document.getElementById('scSaveDone') as HTMLElement).style.display = 'none';
    (document.getElementById('scSaveBtn') as HTMLButtonElement).disabled = false;
    (document.getElementById('gameArea') as HTMLElement).style.display = 'none';
    (document.getElementById('gameOver') as HTMLElement).style.display = 'flex';
    (document.getElementById('finalScore') as HTMLElement).textContent = String(matches);
    const bestEl = document.getElementById('bestScore');
    if (bestEl) bestEl.textContent = String(best);
    (document.getElementById('timer') as HTMLElement).classList.remove('warning');

    if (getUniverseSession()) {
      saveUniverseScore('speed-challenge', matches, `${matches} pairs in 60s`);
    }
  }

  function init() {
    if (!verbs.length) loadData();

    document.getElementById('startBtn')!.onclick = startGame;
    document.getElementById('restartBtn')!.onclick = startGame;

    document.getElementById('scSaveBtn')!.onclick = () => {
      const name = (document.getElementById('scNameInput') as HTMLInputElement).value.trim();
      if (!name) return;
      saveScore('speed-challenge', matches, `${matches} pairs in 60s`, name);
      (document.getElementById('scSaveDone') as HTMLElement).style.display = 'block';
      (document.getElementById('scSaveBtn') as HTMLButtonElement).disabled = true;
    };
  }

  document.addEventListener('astro:page-load', init);
  init();
</script>

<style>
  .page {
    min-height: 100dvh;
    background: linear-gradient(145deg, #f093fb 0%, #f5576c 100%);
    display: flex;
    flex-direction: column;
  }

  .top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.25rem;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  h1 {
    color: white;
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    flex: 1;
    text-align: center;
  }

  .timer-badge {
    background: rgba(255,255,255,0.25);
    color: white;
    font-size: 1.2rem;
    font-weight: 800;
    padding: 0.45rem 1rem;
    border-radius: var(--r-sm);
    min-width: 66px;
    text-align: center;
    transition: background 0.3s;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .timer-badge.warning {
    background: #ef4444;
    animation: pulse 0.6s infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.08); }
  }

  .game-area {
    flex: 1;
    padding: 0.75rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  /* ── Panels (instructions / game over) ── */
  .panel {
    flex: 1;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: var(--r-xl);
    padding: 2.5rem 2rem;
  }

  .center-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    text-align: center;
  }

  .panel-icon { font-size: 3.5rem; line-height: 1; }

  .panel h2 {
    font-size: 1.8rem;
    font-weight: 800;
    color: white;
  }

  .panel p {
    color: rgba(255,255,255,0.85);
    font-size: 1rem;
    line-height: 1.6;
    font-weight: 500;
  }

  .big-result {
    font-size: 1.3rem !important;
  }

  .best-result {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.65);
    font-weight: 500;
  }

  .action-btn {
    font-family: var(--font);
    font-size: 1.1rem;
    font-weight: 700;
    border: none;
    border-radius: var(--r-md);
    padding: 0.85rem 2.5rem;
    cursor: pointer;
    transition: transform var(--t), box-shadow var(--t);
    min-height: 52px;
  }

  .action-btn:hover { transform: translateY(-3px); box-shadow: var(--sh-md); }
  .action-btn:active { transform: translateY(0); }

  .btn--pink {
    background: white;
    color: #f5576c;
  }

  /* ── Game play ── */
  .game-play {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 0;
  }

  .score-strip {
    text-align: center;
    color: white;
    font-size: 1.1rem;
    font-weight: 700;
    background: rgba(255,255,255,0.18);
    border-radius: var(--r-sm);
    padding: 0.6rem 1rem;
    flex-shrink: 0;
  }

  .score-strip strong { font-size: 1.3rem; }

  .columns-wrap {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 2px 1fr;
    gap: 0.75rem;
    min-height: 0;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: var(--r-xl);
    padding: 1.25rem 1rem;
  }

  .divider {
    background: rgba(255,255,255,0.25);
    border-radius: 2px;
    align-self: stretch;
  }

  .verb-col h3 {
    text-align: center;
    color: rgba(255,255,255,0.8);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .verb-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.vb-btn) {
    width: 100%;
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 700;
    padding: 0.75rem 0.5rem;
    border: 2px solid rgba(255,255,255,0.35);
    border-radius: var(--r-md);
    background: rgba(255,255,255,0.9);
    color: #44105a;
    cursor: pointer;
    transition: all var(--t);
    min-height: 50px;
  }

  :global(.vb-btn:hover:not(:disabled)) {
    border-color: #f5576c;
    background: #f5576c;
    color: white;
    transform: scale(1.03);
  }

  :global(.vb-btn.selected) {
    background: #f5576c;
    color: white;
    border-color: white;
    box-shadow: 0 0 0 3px white, 0 6px 20px rgba(245,87,108,0.55);
    transform: scale(1.06);
    position: relative;
    z-index: 1;
  }

  :global(.vb-btn.matched) {
    color: white;
    border-color: transparent;
    cursor: not-allowed;
    opacity: 0.92;
    box-shadow: 0 3px 10px rgba(0,0,0,0.2);
  }

  :global(.vb-btn.wrong) {
    animation: shakeH 0.4s ease;
    border-color: #ef4444;
    background: #fef2f2;
  }

  @keyframes shakeH {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-8px); }
    75% { transform: translateX(8px); }
  }

  @media (min-width: 600px) {
    .top-bar { padding: 1rem 1.75rem; }
    h1 { font-size: 1.5rem; }
    .game-area { padding: 1rem 1.75rem 1.5rem; gap: 1rem; }
    :global(.vb-btn) { font-size: 1.1rem; min-height: 56px; }
  }

  @media (min-width: 1024px) {
    .game-area { padding: 1.25rem 2.5rem 2rem; }
    :global(.vb-btn) { font-size: 1.2rem; min-height: 60px; }
  }
</style>
